{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "images.faces_detected",
  "description": "DC → O2: resultado de detección de caras",
  "type": "object",
  "required": ["GUID_Solicitud", "s3_key", "faces"],
  "properties": {
    "GUID_Solicitud": { "type": "string", "format": "uuid" },
    "s3_key": { "type": "string" },
    "faces": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id_imagen", "bbox"],
        "properties": {
          "id_imagen": { "type": "integer" },
          "bbox": {
            "type": "object",
            "required": ["x", "y", "w", "h"],
            "properties": {
              "x": { "type": "integer" },
              "y": { "type": "integer" },
              "w": { "type": "integer" },
              "h": { "type": "integer" }
            }
          }
        }
      }
    }
  }
}
